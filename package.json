{
  "name": "nythis-obsidian-reverse-prompt",
  "private": false,
  "version": "1.4.0",
  "type": "module",
  "description": "Free, open-source reverse prompt engineer. Paste any output, get the prompt that produced it. Runs 100% in your browser. No API keys required.",
  "license": "MIT",
  "homepage": "https://github.com/BIGSTODG120/NYTHIS-OBSIDIAN-REVERSE-PROMPT-ENGINEER",
  "repository": {
    "type": "git",
    "url": "https://github.com/BIGSTODG120/NYTHIS-OBSIDIAN-REVERSE-PROMPT-ENGINEER.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test:engine": "tsx src/engine/__test__.ts",
    "test:smoke:full": "tsx src/engine/__smoke_full__.ts",
    "test:calibration": "tsx src/engine/__calibration__.ts",
    "test:fuzz": "tsx src/engine/__fuzz__.ts",
    "test:determinism": "tsx src/engine/__determinism__.ts",
    "test:all": "npm run test:engine && npm run test:calibration && npm run test:fuzz && npm run test:determinism"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
